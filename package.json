{
  "name": "roland",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Roland — a beautiful blue-duotone dithered-ASCII jousting math duel.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:single": "tsc --noEmit && vite build --mode single",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:art": "node scripts/gen-ascii.mjs"
  },
  "devDependencies": {
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^2.1.8"
  }
}
